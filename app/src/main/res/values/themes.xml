<resources>
    <!-- Normal app theme: solid black window behind the dark Compose UI. -->
    <style name="Theme.OdinsGolf" parent="@android:style/Theme.DeviceDefault">
        <item name="android:windowBackground">@color/odin_bg</item>
        <item name="android:colorBackground">@color/odin_bg</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Launch theme: the OS launch phase IS the brand moment — the OdinsGolf
         logo on white, held briefly (see MainActivity.keepOnScreen). No separate
         Compose splash, so there is no white-then-logo double take. -->
    <style name="Theme.OdinsGolf.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_logo_inset</item>
        <item name="postSplashScreenTheme">@style/Theme.OdinsGolf</item>
    </style>
</resources>
