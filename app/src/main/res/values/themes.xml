<resources>
    <!-- Normal app theme: solid black window behind the dark Compose UI. -->
    <style name="Theme.OdinsGolf" parent="@android:style/Theme.DeviceDefault">
        <item name="android:windowBackground">@color/odin_bg</item>
        <item name="android:colorBackground">@color/odin_bg</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Launch theme: the OS launch phase IS the only splash — the OdinsGolf
         emblem (no wordmark) on white, which fills the circular splash mask so it
         shows big and uncropped. Held briefly (MainActivity.keepOnScreen). No
         Compose splash, so there is no second logo / double take. -->
    <style name="Theme.OdinsGolf.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/odins_emblem</item>
        <item name="postSplashScreenTheme">@style/Theme.OdinsGolf</item>
    </style>
</resources>
