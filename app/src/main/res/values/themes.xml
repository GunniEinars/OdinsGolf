<resources>
    <!-- Normal app theme: solid black window behind the dark Compose UI. -->
    <style name="Theme.OdinsGolf" parent="@android:style/Theme.DeviceDefault">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:colorBackground">@color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Launch theme: clean white OS launch phase (transparent icon, no clipped
         logo), then our full-screen Compose splash shows the whole logo. -->
    <style name="Theme.OdinsGolf.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.OdinsGolf</item>
    </style>
</resources>
