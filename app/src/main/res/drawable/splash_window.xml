<?xml version="1.0" encoding="utf-8"?>
<!-- Launch window background: the logo at a sensible size on white, so the very
     first frame already shows the full logo (no blank-white / tiny-icon stage). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/white" />
    <item
        android:width="320dp"
        android:height="320dp"
        android:gravity="center">
        <bitmap
            android:src="@drawable/odins_logo"
            android:gravity="center" />
    </item>
</layer-list>
